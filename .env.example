# Pick a provider: "ollama" (local, open-source) or "anthropic" (cloud)
FREE_AGENT_PROVIDER=ollama

# --- Ollama (local, open-source) ---
# Run `ollama pull <model>` first. Must be a model with tool-calling support:
# qwen2.5, qwen3, llama3.1+, mistral-nemo, hermes3, command-r, etc.
FREE_AGENT_OLLAMA_MODEL=qwen2.5:7b
FREE_AGENT_OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic (cloud) ---
# Only required when FREE_AGENT_PROVIDER=anthropic
ANTHROPIC_API_KEY=
FREE_AGENT_ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Shared ---
FREE_AGENT_TEMPERATURE=0.7
FREE_AGENT_MAX_TOKENS=4096
FREE_AGENT_LOG_LEVEL=WARNING

# Set to 1 to let the agent read/write files in the cwd by default.
# The CLI flag `free-agent --writable` overrides this per-invocation.
# Paths are scoped to cwd (no escape via .. / ~ / absolute outside-root).
FREE_AGENT_WRITABLE=0
